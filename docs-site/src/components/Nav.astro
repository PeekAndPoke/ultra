---
import { githubRepo } from '../data/site';
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const normalize = (p: string) => p.replace(/\/+$/, '') || '/';

const toolPrefixes = [
    '/ultra/tools/', '/ultra/kontainer/', '/ultra/slumber/', '/ultra/mutator/',
    '/ultra/streams/', '/ultra/datetime/', '/ultra/cache/', '/ultra/maths/',
];

const navLinks = [
    {href: '/', label: 'Home', exact: true, prefixes: [] as string[]},
    {href: '/ultra/tools/', label: 'Tools', exact: false, prefixes: toolPrefixes},
    {href: '/ultra/kraft/', label: 'Kraft', exact: false, prefixes: ['/ultra/kraft/']},
    {
        href: '/ultra/funktor/',
        label: 'Funktor',
        exact: false,
        prefixes: ['/ultra/funktor/', '/ultra/karango/', '/ultra/monko/']
    },
];

function isActive(link: typeof navLinks[number]) {
  const norm = normalize(link.href);
  if (link.exact) return currentPath === norm;
    if (link.prefixes.length > 0) {
        return link.prefixes.some(p => {
            const np = normalize(p);
            return currentPath === np || currentPath.startsWith(np + '/');
        });
    }
  return currentPath === norm || currentPath.startsWith(norm + '/');
}
---

<nav id="main-nav"
     class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-surface-900/65 transition-shadow duration-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-lg font-bold text-white hover:text-brand-400 transition-colors">
        peekandpoke.io
      </a>
      <div class="flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
              isActive(link)
                  ? 'text-brand-400 underline underline-offset-4 decoration-brand-400/60'
                  : 'text-gray-400 hover:text-white',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href={githubRepo}
          target="_blank"
          rel="noopener"
          class="ml-2 px-3 py-2 rounded-lg text-sm text-gray-400 hover:text-white hover:bg-white/5 transition-colors"
        >
          GitHub
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  if (nav) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          if (scrollY > 40) {
            nav.style.boxShadow = '0 4px 24px rgba(212, 160, 58, 0.06), 0 1px 4px rgba(0, 0, 0, 0.3)';
            nav.style.borderBottomColor = 'rgba(212, 160, 58, 0.15)';
          } else {
            nav.style.boxShadow = 'none';
            nav.style.borderBottomColor = 'rgba(255, 255, 255, 0.1)';
          }
          ticking = false;
        });
        ticking = true;
      }
    });
  }
</script>
