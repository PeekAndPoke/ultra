---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { githubRepo, mavenCentralUrl, ultraGroup } from '../data/site';

const libraries = [
  {
    name: 'Kraft',
    tagline: 'Build SPAs in pure Kotlin',
    description: 'A component-based SPA framework using Preact under the hood. Type-safe HTML DSL, reactive state, routing, forms, and a beautiful SemanticUI integration.',
    href: '/ultra/kraft/',
    ready: true,
  },
  {
    name: 'Mutator',
    tagline: 'Mutate the immutable',
    description: 'KSP-generated code that lets you mutate deeply nested immutable data structures without copy() hell.',
    href: '/ultra/mutator/',
    ready: false,
  },
  {
    name: 'Kontainer',
    tagline: 'Dependency injection, done right',
    description: 'A lightweight DI container built around per-request scoping. Fresh containers per unit of work, stateful dynamic services, and validated dependency graphs — no annotations, no surprises.',
    href: '/ultra/kontainer/',
    ready: true,
  },
  {
    name: 'Slumber',
    tagline: 'Serialization that sleeps easy',
    description: 'Kotlin-first serialization that understands nullable types, default values, and sealed classes. No annotations needed.',
    href: '/ultra/slumber/',
    ready: true,
  },
  {
    name: 'Streams',
    tagline: 'Reactive streams that always have a value',
    description: 'A lightweight reactive streams library for Kotlin Multiplatform. Always-has-a-value semantics, lazy subscriptions, and composable operators — no marble diagrams required.',
    href: '/ultra/streams/',
    ready: true,
  },
  {
    name: 'Karango',
    tagline: 'Type-safe ArangoDB',
    description: 'Write ArangoDB queries in Kotlin with full type safety. KSP generates the boilerplate, you write the logic.',
    href: '/ultra/karango/',
    ready: true,
  },
  {
    name: 'Funktor',
    tagline: 'Full-stack Kotlin on Ktor',
    description: 'Everything you need for client-server apps. Auth, REST, clustering, and static web — all in Kotlin.',
    href: '/ultra/funktor/',
    ready: false,
  },
];
---

<BaseLayout title="Home">
  <Nav />

  <!-- Hero -->
  <section class="pt-32 pb-20 px-4">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-5xl sm:text-6xl font-extrabold tracking-tight text-white mb-6">
        Kotlin libraries that
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-300 to-brand-500">
          get out of your way
        </span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
        Open-source tools for building real applications in Kotlin.
        Dependency injection, serialization, reactive state, immutable data mutation, SPAs, database access
        — designed to work together, type-safe, and free of ceremony.
      </p>
    </div>
  </section>

  <!-- Libraries Grid -->
  <section class="pb-32 px-4">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-2xl font-bold text-white mb-8 text-center">The Libraries</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {libraries.map(lib => {
          const classes = lib.ready
              ? 'group block p-6 rounded-xl border transition-all duration-200 border-brand-400/30 bg-brand-400/5 hover:border-brand-400/60 hover:bg-brand-400/10'
              : 'block p-6 rounded-xl border transition-all duration-200 border-white/10 bg-white/[0.02] cursor-default';
          const content = (
              <>
                <div class="flex items-center justify-between mb-3">
                  <h3 class:list={[
                    'text-lg font-bold transition-colors',
                    lib.ready ? 'text-white group-hover:text-brand-400' : 'text-gray-500',
                  ]}>
                    {lib.name}
                  </h3>
                  {!lib.ready && (
                      <span class="text-xs text-gray-500 border border-white/10 px-2 py-0.5 rounded-full">
                    coming soon
                  </span>
                  )}
                </div>
                <p class:list={['text-sm font-medium mb-2', lib.ready ? 'text-brand-400' : 'text-brand-400/50']}>
                  {lib.tagline}
                </p>
                <p class:list={['text-sm leading-relaxed', lib.ready ? 'text-gray-400' : 'text-gray-600']}>
                  {lib.description}
                </p>
              </>
          );
          return lib.ready
              ? <a href={lib.href} class={classes}>{content}</a>
              :
              <div class={classes}>{content}</div>;
        })}
      </div>
    </div>
  </section>

  <!-- Maven Central -->
  <section class="pb-20 px-4">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-gray-500 text-sm">
        Published on Maven Central as
        <a href={mavenCentralUrl} target="_blank" rel="noopener" class="text-brand-400 hover:text-brand-300 transition-colors"><code>{ultraGroup}</code></a>
      </p>
    </div>
  </section>
</BaseLayout>
