---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Aside from '../components/Aside.astro';
import { githubRepo, mavenCentralUrl, ultraGroup } from '../data/site';

const libraries = [
  {
    name: 'Kraft',
    tagline: 'SPAs in pure Kotlin',
    description: 'A component-based SPA framework using Preact under the hood. Type-safe HTML DSL, reactive state, routing, forms, and SemanticUI integration.',
    aside: 'Kotlin in the browser. No JavaScript was harmed.',
    href: '/ultra/kraft/',
    ready: true,
  },
  {
    name: 'Mutator',
    tagline: 'Modify immutable data structures',
    description: 'KSP-generated code that lets you modify deeply nested immutable data structures with simple property assignments.',
    aside: 'Because copy()-hell makes developers yell.',
    href: '/ultra/mutator/',
    ready: true,
  },
  {
    name: 'Kontainer',
    tagline: 'Lightweight dependency injection',
    description: 'A DI container built around per-request scoping. Fresh containers per unit of work, dynamic services, and validated dependency graphs.',
    aside: 'Yes, we know there are other DI containers.',
    href: '/ultra/kontainer/',
    ready: true,
  },
  {
    name: 'Slumber',
    tagline: 'Kotlin-first serialization',
    description: 'Serialization that understands nullable types, default values, and sealed classes without annotation clutter.',
    aside: 'The name is a pun. We chose it anyway.',
    href: '/ultra/slumber/',
    ready: true,
  },
  {
    name: 'Streams',
    tagline: 'Reactive values',
    description: 'A lightweight reactive streams library for Kotlin Multiplatform. Always-has-a-value semantics, lazy subscriptions, and composable operators.',
    aside: 'Like RxJS, but smaller. Much, much smaller.',
    href: '/ultra/streams/',
    ready: true,
  },
  {
    name: 'Karango',
    tagline: 'Type-safe ArangoDB queries',
    description: 'Write ArangoDB queries in Kotlin with compile-time safety. KSP generates the boilerplate.',
    aside: 'For the three of us who use ArangoDB and Kotlin.',
    href: '/ultra/karango/',
    ready: true,
  },
  {
    name: 'Funktor',
    tagline: 'Full-stack Kotlin on Ktor',
    description: 'Building blocks for client-server apps. Auth, REST, clustering, and static web.',
    aside: 'We needed glue. So we wrote a framework. As one does.',
    href: '/ultra/funktor/',
    ready: false,
  },
];
---

<BaseLayout title="Home">
  <Nav />

  <!-- Hero -->
  <section class="pt-32 pb-20 px-4">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-5xl sm:text-6xl font-extrabold tracking-tight text-white mb-6">
        The tools
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-300 to-brand-500">
          we use
        </span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-4 leading-relaxed">
        Open-source Kotlin libraries for dependency injection, serialization, reactive state,
        immutable data mutation, SPAs, and database access.
        We built them for our own projects &mdash; and you can use them too.
      </p>
      <p class="text-sm text-brand-300/60 italic max-w-lg mx-auto">
        Started as one library. Things got a little out of hand.
      </p>
    </div>
  </section>

  <!-- Libraries Grid -->
  <section class="pb-32 px-4">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {libraries.map(lib => {
          const classes = lib.ready
              ? 'group flex flex-col p-6 rounded-xl border transition-all duration-200 border-brand-400/30 bg-brand-400/5 hover:border-brand-400/60 hover:bg-brand-400/10'
              : 'flex flex-col p-6 rounded-xl border transition-all duration-200 border-white/10 bg-white/[0.02] cursor-default';
          const content = (
              <>
                <div class="flex items-center justify-between mb-3">
                  <h3 class:list={[
                    'text-lg font-bold transition-colors',
                    lib.ready ? 'text-white group-hover:text-brand-400' : 'text-gray-500',
                  ]}>
                    {lib.name}
                  </h3>
                  {!lib.ready && (
                      <span class="text-xs text-gray-500 border border-white/10 px-2 py-0.5 rounded-full">
                    coming soon
                  </span>
                  )}
                </div>
                <p class:list={['text-sm font-medium mb-2', lib.ready ? 'text-brand-400' : 'text-brand-400/50']}>
                  {lib.tagline}
                </p>
                <p class:list={['text-sm leading-relaxed', lib.ready ? 'text-gray-400' : 'text-gray-600']}>
                  {lib.description}
                </p>
                {lib.aside && (
                    <div class="mt-auto pt-4">
                      <p class="text-xs text-brand-100/60 italic pt-3 border-t border-white/5">
                        &ldquo;{lib.aside}&rdquo;
                      </p>
                    </div>
                )}
              </>
          );
          return lib.ready
              ? <a href={lib.href} class={classes}>{content}</a>
              :
              <div class={classes}>{content}</div>;
        })}
      </div>
    </div>
  </section>

  <!-- Maven Central -->
  <section class="pb-20 px-4">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-gray-500 text-sm">
        Published on Maven Central as
        <a href={mavenCentralUrl} target="_blank" rel="noopener" class="text-brand-400 hover:text-brand-300 transition-colors"><code>{ultraGroup}</code></a>
      </p>
    </div>
  </section>
</BaseLayout>
