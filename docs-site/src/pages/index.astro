---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

const libraries = [
  {
    name: 'Kraft',
    tagline: 'Build SPAs in pure Kotlin',
    description: 'A component-based SPA framework using Preact under the hood. Type-safe HTML DSL, reactive state, routing, forms, and a beautiful SemanticUI integration.',
    href: '/ultra/kraft/',
    ready: true,
  },
  {
    name: 'Mutator',
    tagline: 'Mutate the immutable',
    description: 'KSP-generated code that lets you mutate deeply nested immutable data structures without copy() hell.',
    href: '/ultra/mutator/',
    ready: false,
  },
  {
    name: 'Kontainer',
    tagline: 'Dependency injection, done right',
    description: 'A compile-time verified DI container. No reflection, no runtime surprises. Define your dependencies, get type-safe injection.',
    href: '/ultra/kontainer/',
    ready: false,
  },
  {
    name: 'Slumber',
    tagline: 'Serialization that sleeps easy',
    description: 'Flexible serialization and deserialization with codec support. Maps, transforms, and validates your data.',
    href: '/ultra/slumber/',
    ready: false,
  },
  {
    name: 'Karango',
    tagline: 'Type-safe ArangoDB',
    description: 'Write ArangoDB queries in Kotlin with full type safety. KSP generates the boilerplate, you write the logic.',
    href: '/ultra/karango/',
    ready: false,
  },
  {
    name: 'Funktor',
    tagline: 'Full-stack Kotlin on Ktor',
    description: 'Everything you need for client-server apps. Auth, REST, clustering, and static web — all in Kotlin.',
    href: '/ultra/funktor/',
    ready: false,
  },
];
---

<BaseLayout title="Home">
  <Nav />

  <!-- Hero -->
  <section class="pt-32 pb-20 px-4">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-5xl sm:text-6xl font-extrabold tracking-tight text-white mb-6">
        Build with
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-300 to-brand-500">
          Kotlin
        </span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
        A collection of battle-tested Kotlin libraries for building modern applications.
        From single-page apps to database access — type-safe, expressive, and ready to use.
      </p>
      <div class="flex gap-4 justify-center">
        <a
          href="/ultra/kraft/"
          class="px-6 py-3 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-500 transition-colors"
        >
          Get started with Kraft
        </a>
        <a
          href="https://github.com/PeekAndPoke/ultra"
          target="_blank"
          rel="noopener"
          class="px-6 py-3 border border-white/20 text-gray-300 font-semibold rounded-lg hover:bg-white/5 transition-colors"
        >
          View on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Libraries Grid -->
  <section class="pb-32 px-4">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-2xl font-bold text-white mb-8 text-center">The Libraries</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {libraries.map(lib => (
          <a
            href={lib.href}
            class:list={[
              'group block p-6 rounded-xl border transition-all duration-200',
              lib.ready
                ? 'border-brand-400/30 bg-brand-400/5 hover:border-brand-400/60 hover:bg-brand-400/10'
                : 'border-white/10 bg-white/[0.02] hover:border-white/20 hover:bg-white/[0.04]',
            ]}
          >
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-lg font-bold text-white group-hover:text-brand-400 transition-colors">
                {lib.name}
              </h3>
              {!lib.ready && (
                <span class="text-xs text-gray-500 border border-white/10 px-2 py-0.5 rounded-full">
                  soon
                </span>
              )}
            </div>
            <p class="text-sm font-medium text-brand-400 mb-2">{lib.tagline}</p>
            <p class="text-sm text-gray-400 leading-relaxed">{lib.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Maven Central -->
  <section class="pb-20 px-4">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-gray-500 text-sm">
        Published on Maven Central as
        <a href="https://search.maven.org/search?q=io.peekandpoke.ultra" target="_blank" rel="noopener" class="text-brand-400 hover:text-brand-300 transition-colors"><code>io.peekandpoke.ultra</code></a>
      </p>
    </div>
  </section>
</BaseLayout>
