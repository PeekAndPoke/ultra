---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="404 — Page Not Found">
    <Nav/>

    <section class="pt-32 pb-20 px-4">
        <div class="mx-auto max-w-2xl text-center">
            <p class="text-brand-400 text-7xl font-extrabold mb-4">404</p>
            <h1 class="text-3xl font-bold text-white mb-4">Page not found</h1>
            <p class="text-gray-400 mb-10">
                The page you're looking for doesn't exist or has been moved.
            </p>
            <a
                    href="/"
                    class="inline-block px-6 py-3 rounded-lg text-sm font-medium text-white bg-brand-400/20 border border-brand-400/40 hover:bg-brand-400/30 transition-colors"
            >
                Back to Home
            </a>
        </div>
    </section>
</BaseLayout>
