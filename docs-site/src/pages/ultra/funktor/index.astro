---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import HilbertBackground from '../../../components/HilbertBackground.astro';
import {categoryTints, githubSource} from '../../../data/site';

const t = categoryTints.funktor;

const modules = [
    {
        href: '/ultra/funktor/core',
        title: 'Core',
        description: 'App lifecycle, type-safe routing, CLI framework, fixtures, configuration, and the repair system.',
    },
    {
        href: '/ultra/funktor/rest',
        title: 'REST',
        description: 'Typed API routes with automatic parameter extraction, authorization DSL, endpoint documentation, SSE support.',
    },
    {
        href: '/ultra/funktor/auth',
        title: 'Auth',
        description: 'Multi-realm authentication. Email/password, Google SSO, GitHub SSO, JWT tokens, and session management.',
    },
    {
        href: '/ultra/funktor/cluster',
        title: 'Cluster',
        description: 'Background jobs with retry and scheduling, file depot, distributed locks, workers, and key-value storage.',
    },
    {
        href: '/ultra/funktor/messaging',
        title: 'Messaging',
        description: 'Email sending with pluggable backends — SendGrid, AWS SES, or custom. Sent message storage and retry.',
    },
    {
        href: '/ultra/funktor/insights',
        title: 'Insights',
        description: 'Zero-config per-request profiling, performance metrics, and a built-in debug GUI for every request.',
    },
    {
        href: '/ultra/funktor/logging',
        title: 'Logging',
        description: 'Structured logging with database persistence, filtering, log levels, and a web UI for browsing logs.',
    },
    {
        href: '/ultra/funktor/staticweb',
        title: 'Static Web',
        description: 'Server-rendered templates, flash sessions, static web resources, cache busting, and asset pipelines.',
    },
    {
        href: '/ultra/funktor/testing',
        title: 'Testing',
        description: 'Test harness with fixtures, Kontainer service injection, and route testing utilities.',
    },
];

const databases = [
    {
        href: '/ultra/karango/',
        title: 'Karango',
        tagline: 'Type-safe ArangoDB',
        description: 'Write ArangoDB queries in Kotlin with compile-time safety. KSP generates the boilerplate. Repository pattern with entity hooks.',
    },
    {
        href: '/ultra/monko/',
        title: 'Monko',
        tagline: 'Type-safe MongoDB',
        description: 'Typed MongoDB repositories with entity lifecycle hooks, index management, and Funktor integration.',
    },
];
---

<BaseLayout title="Funktor" description="A modular Ktor-based server framework for Kotlin">
    <HilbertBackground tint={categoryTints.funktor.light}/>
    <Nav/>

    <section class="pt-32 pb-12 px-4">
        <div class="mx-auto max-w-5xl">
            <div class="flex items-center justify-between mb-4">
                <h1 class="text-4xl font-extrabold text-white">Funktor</h1>
                <a href={githubSource.funktor} target="_blank" rel="noopener"
                   class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-brand-400 transition-colors">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
                    </svg>
                    View source
                </a>
            </div>
            <p class="text-xl text-gray-400 mb-2">
                A modular server framework built on Ktor.
            </p>
            <p class="text-sm text-gray-500 mb-12">
                Auth, REST APIs, background jobs, messaging, profiling, and more —
                wired together with Kontainer for per-request dependency injection.
                Use what you need, ignore the rest.
            </p>

            <div class="mb-10">
                <h2 class="text-lg font-bold text-gray-500 uppercase tracking-wide mb-3">Modules</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {modules.map(mod => (
                            <a
                                    href={mod.href}
                                    class="group block p-5 rounded-xl border border-brand-400/20 bg-[#161a2a]/65 hover:border-brand-400/50 hover:bg-[#161a2a]/75 hover:-translate-y-0.5 transition-all duration-300"
                                    style={`--glow: ${t.glow}; --glow-sm: ${t.glowSm};`}
                                    onmouseover="this.style.boxShadow='0 0 25px var(--glow), 0 0 8px var(--glow-sm)'"
                                    onmouseout="this.style.boxShadow='none'"
                            >
                                <h3 class="text-white font-bold mb-1">{mod.title}</h3>
                                <p class="text-sm text-gray-400">{mod.description}</p>
                            </a>
                    ))}
                </div>
            </div>

            <div class="mb-10">
                <h2 class="text-lg font-bold text-gray-500 uppercase tracking-wide mb-3">Databases</h2>
                <p class="text-sm text-gray-500 mb-4">
                    Funktor modules are database-agnostic. Each module declares what it needs; you choose
                    which backend provides it. Mix Karango and Monko in the same app.
                </p>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {databases.map(db => (
                            <a
                                    href={db.href}
                                    class="group block p-5 rounded-xl border border-brand-400/20 bg-[#161a2a]/65 hover:border-brand-400/50 hover:bg-[#161a2a]/75 hover:-translate-y-0.5 transition-all duration-300"
                                    style={`--glow: ${t.glow}; --glow-sm: ${t.glowSm};`}
                                    onmouseover="this.style.boxShadow='0 0 25px var(--glow), 0 0 8px var(--glow-sm)'"
                                    onmouseout="this.style.boxShadow='none'"
                            >
                                <div class="flex items-baseline gap-2 mb-1">
                                    <h3 class="text-white font-bold">{db.title}</h3>
                                    <span class="text-sm text-brand-400 font-medium">{db.tagline}</span>
                                </div>
                                <p class="text-sm text-gray-400">{db.description}</p>
                            </a>
                    ))}
                </div>
            </div>

            <div class="mb-10">
                <h2 class="text-lg font-bold text-gray-500 uppercase tracking-wide mb-3">Getting Started</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <a
                            href="/ultra/funktor/getting-started"
                            class="group block p-5 rounded-xl border border-brand-400/20 bg-[#161a2a]/65 hover:border-brand-400/50 hover:bg-[#161a2a]/75 hover:-translate-y-0.5 transition-all duration-300"
                            style={`--glow: ${t.glow}; --glow-sm: ${t.glowSm};`}
                            onmouseover="this.style.boxShadow='0 0 25px var(--glow), 0 0 8px var(--glow-sm)'"
                            onmouseout="this.style.boxShadow='none'"
                    >
                        <h3 class="text-white font-bold mb-1">Set up Funktor</h3>
                        <p class="text-sm text-gray-400">Dependencies, configuration, first module, first route.</p>
                    </a>
                </div>
            </div>
    </div>
    </section>
</BaseLayout>
