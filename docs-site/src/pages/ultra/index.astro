---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';

const libs = [
  {
    name: 'Kraft',
    tagline: 'Build SPAs in pure Kotlin',
    href: '/ultra/kraft/',
    ready: true,
  },
  { name: 'Mutator', tagline: 'Mutate the immutable', href: '/ultra/mutator/', ready: false },
  { name: 'Kontainer', tagline: 'Dependency injection', href: '/ultra/kontainer/', ready: true },
  { name: 'Slumber', tagline: 'Serialization', href: '/ultra/slumber/', ready: false },
  { name: 'Karango', tagline: 'Type-safe ArangoDB', href: '/ultra/karango/', ready: false },
  { name: 'Funktor', tagline: 'Full-stack Kotlin on Ktor', href: '/ultra/funktor/', ready: false },
];
---

<BaseLayout title="Ultra">
  <Nav />

  <section class="pt-32 pb-16 px-4">
    <div class="mx-auto max-w-4xl">
      <h1 class="text-4xl font-extrabold text-white mb-4">Ultra</h1>
      <p class="text-xl text-gray-400 mb-12">
        A Kotlin multiplatform monorepo. Six libraries, one ecosystem.
        Published on Maven Central as <code>io.peekandpoke.ultra</code>.
      </p>

      <div class="space-y-4">
        {libs.map(lib => (
          <a
            href={lib.href}
            class:list={[
              'flex items-center justify-between p-5 rounded-xl border transition-all',
              lib.ready
                ? 'border-brand-400/30 bg-brand-400/5 hover:border-brand-400/60'
                : 'border-white/10 bg-white/[0.02] hover:border-white/20',
            ]}
          >
            <div>
              <h2 class="text-lg font-bold text-white">{lib.name}</h2>
              <p class="text-sm text-gray-400">{lib.tagline}</p>
            </div>
            <span class:list={[
              'text-xs px-2 py-1 rounded-full',
              lib.ready ? 'text-brand-400 bg-brand-400/10' : 'text-gray-500 border border-white/10',
            ]}>
              {lib.ready ? 'docs ready' : 'coming soon'}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
