---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import {karangoSidebar} from '../../../data/karango-sidebar';
import {Code} from 'astro:components';
import {dep} from '../../../data/site';
---

<DocsLayout title="Getting Started with Karango" sidebar={karangoSidebar}
            description="Set up Karango and write your first type-safe ArangoDB query">

    <h1>Getting Started</h1>

    <p class="text-xl text-gray-400 !mt-2 !mb-8">
        Connect to ArangoDB, define an entity, and run your first type-safe query.
    </p>

    <h2>1. Add dependencies</h2>

    <Code code={`plugins {
    kotlin("jvm")
    id("com.google.devtools.ksp") // For type-safe property generation
}

dependencies {
    implementation("${dep.karangoCore}")
    ksp("${dep.karangoKsp}")
}`} lang="kotlin" theme="vitesse-dark"/>

    <h2>2. Define your entity</h2>

    <p>Annotate data classes with <code>@Vault</code>. KSP generates type-safe property accessors at compile time.</p>

    <Code code={`import de.peekandpoke.ultra.vault.Vault

@Vault
data class Person(
    val name: String,
    val age: Int,
    val email: String? = null,
)`} lang="kotlin" theme="vitesse-dark"/>

    <h2>3. Create a repository</h2>

    <Code code={`import de.peekandpoke.karango.vault.EntityRepository
import de.peekandpoke.karango.vault.KarangoDriver
import de.peekandpoke.ultra.reflection.kType

class PersonsRepo(driver: KarangoDriver) : EntityRepository<Person>(
    name = "persons",          // ArangoDB collection name
    storedType = kType(),      // Type reference for serialization
    driver = driver,
)`} lang="kotlin" theme="vitesse-dark"/>

    <h2>4. Configure the connection</h2>

    <Code code={`import de.peekandpoke.karango.config.ArangoDbConfig

val config = ArangoDbConfig(
    host = "localhost",
    port = 8529,
    user = "root",
    password = "",
    database = "my_app",
)`} lang="kotlin" theme="vitesse-dark"/>

    <p>With Kontainer (dependency injection):</p>

    <Code code={`import de.peekandpoke.karango.karango

kontainer {
    karango(config)

    // Register your repositories
    singleton(PersonsRepo::class)
}`} lang="kotlin" theme="vitesse-dark"/>

    <h2>5. Basic CRUD</h2>

    <Code code={`// Insert
val stored = repo.insert(Person("Alice", 30, "alice@example.com"))
// stored._id = "persons/abc123"
// stored._key = "abc123"
// stored.value = Person(name="Alice", age=30, ...)

// Find by ID
val found = repo.findById(stored._id)

// Update
repo.save(found!!.map { it.copy(age = 31) })

// Delete
repo.remove(found)

// Find all
val everyone = repo.findAll().toList()`} lang="kotlin" theme="vitesse-dark"/>

    <h2>6. Your first query</h2>

    <Code code={`// Type-safe query with the Karango DSL
val results = repo.findList {
    FOR(repo) { person ->
        FILTER(person.age GTE 18)
        SORT(person.name.ASC)
        RETURN(person)
    }
}

// results: List<Stored<Person>>`} lang="kotlin" theme="vitesse-dark"/>

    <p>The <code>person.age</code> and <code>person.name</code> accessors are generated by KSP — they're compile-time
        checked. If you rename a field in the data class, the compiler catches every query that references it.</p>

    <div class="not-prose mt-8 flex gap-4">
        <a href="/ultra/karango/entity-model"
           class="inline-flex items-center px-6 py-3 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-500 transition-colors">
            Entity model &rarr;
        </a>
    </div>

</DocsLayout>
