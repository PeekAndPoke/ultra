            <td class="py-2"><code>UNSET(document, attr1, …)</code></td>
            <td class="py-2">Return a copy of the document without given attributes</td>
        </tr>
        </tbody>
    </table>

    <h2>Type checks</h2>

    <table class="w-full text-sm text-left">
        <thead>
        <tr class="border-b border-white/10">
            <th class="py-2 text-white font-semibold w-1/3">Function</th>
            <th class="py-2 text-white font-semibold">Description</th>
        </tr>
        </thead>
        <tbody class="text-gray-400">
        <tr class="border-b border-white/5">
            <td class="py-2"><code>IS_NULL(expr)</code></td>
            <td class="py-2">Value is <code>null</code></td>
        </tr>
        <tr class="border-b border-white/5">
            <td class="py-2"><code>IS_NOT_NULL(expr)</code></td>
