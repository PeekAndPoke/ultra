        <tr class="border-b border-white/5">
            <td class="py-2"><code>IS_STRING(expr)</code></td>
            <td class="py-2">Value is a string</td>
        </tr>
        <tr class="border-b border-white/5">
            <td class="py-2"><code>IS_ARRAY(expr)</code> / <code>IS_LIST(expr)</code></td>
            <td class="py-2">Value is an array</td>
        </tr>
        <tr class="border-b border-white/5">
            <td class="py-2"><code>IS_OBJECT(expr)</code> / <code>IS_DOCUMENT(expr)</code></td>
            <td class="py-2">Value is an object / document</td>
        </tr>
        <tr class="border-b border-white/5">
            <td class="py-2"><code>IS_DATESTRING(expr)</code></td>
            <td class="py-2">Value is a parseable date string</td>
