        </tr>
        <tr class="border-b border-white/5">
            <td class="py-2"><code>IS_BOOL(expr)</code></td>
            <td class="py-2">Value is a boolean</td>
        </tr>
        <tr class="border-b border-white/5">
            <td class="py-2"><code>IS_NUMBER(expr)</code></td>
            <td class="py-2">Value is a number</td>
