---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Aside from '../../../components/Aside.astro';
import {monkoSidebar} from '../../../data/monko-sidebar';
import {Code} from 'astro:components';
import {dep} from '../../../data/site';
---

<DocsLayout title="Getting Started" sidebar={monkoSidebar} description="Set up Monko for MongoDB access">

    <h1>Getting Started</h1>

    <p class="text-xl text-gray-400 !mt-2 !mb-8">
        From dependency to your first typed query in six steps.
    </p>

    <h2>1. Add the dependencies</h2>

    <Code code={`// build.gradle.kts
plugins {
    kotlin("jvm")
    id("com.google.devtools.ksp")
}

dependencies {
    implementation("${dep.monko}")
    ksp("${dep.monko}")  // KSP processor for type-safe property paths
}`} lang="kotlin" theme="vitesse-dark"/>

    <h2>2. Define an entity</h2>

    <p>Annotate your data class with <code>@Vault</code>. KSP generates type-safe property accessors at compile time.
    </p>

    <Code code={`import io.peekandpoke.ultra.vault.Vault

@Vault
data class Person(
    val name: String,
    val age: Int,
    val email: String,
    val address: Address = Address(),
)

@Vault
data class Address(
    val city: String = "",
    val zip: String = "",
)`} lang="kotlin" theme="vitesse-dark"/>

    <h2>3. Create a repository</h2>

    <Code code={`import io.peekandpoke.monko.MonkoRepository
import io.peekandpoke.monko.MonkoDriver

class PersonsRepo(driver: MonkoDriver) : MonkoRepository<Person>(
    name = "persons",
    storedType = kType(),
    driver = driver,
)`} lang="kotlin" theme="vitesse-dark"/>

    <h2>4. Configure the connection</h2>

    <Code code={`import io.peekandpoke.monko.MongoDbConfig

val config = MongoDbConfig(
    connectionString = "mongodb://root:root@localhost:27017",
    database = "my_app",
)`} lang="kotlin" theme="vitesse-dark"/>

    <h2>5. Basic CRUD</h2>

    <Code code={`// Insert
val stored = repo.insert("person-1", Person(name = "Alice", age = 30, email = "alice@example.com"))
// stored._id   -> "persons/person-1"
// stored._key  -> "person-1"
// stored() -> Person(name="Alice", ...)

// Find by ID
val found = repo.findById("persons/person-1")

// Update
val updated = found!!.modify { copy(age = 31) }
repo.save(updated)

// Atomic read-modify-write
repo.modifyById("persons/person-1") { copy(age = it.age + 1) }

// Delete
repo.remove("persons/person-1")

// Find all
val everyone = repo.findAll()`} lang="kotlin" theme="vitesse-dark"/>

    <h2>6. Your first typed query</h2>

    <Code code={`val adults = repo.find { r ->
    filter(r.age.gte(18))
    sort(r.name.asc)
    limit(20)
}`} lang="kotlin" theme="vitesse-dark"/>

    <p>The <code>r.age</code> and <code>r.name</code> accessors are generated by KSP from
        the <code>Person</code> data class. Rename a field and the query breaks at compile time,
        not at runtime.</p>

    <Aside>That's it. Entity, repository, config, query. Everything else builds on these foundations.</Aside>

    <div class="mt-12">
        <a href="/ultra/monko/entity-model"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-brand-400/10 text-brand-400 border border-brand-400/30 hover:bg-brand-400/20 transition-all font-medium">
            Entity Model &rarr;
        </a>
    </div>

</DocsLayout>
