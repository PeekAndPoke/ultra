---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import HilbertBackground from '../../../components/HilbertBackground.astro';
import {categoryTints, kraftExamples, githubSource} from '../../../data/site';

const t = categoryTints.kraft;

const sections = [
    {
        title: 'Overview',
        items: [
            {
                href: '/ultra/kraft/getting-started',
                title: 'Getting Started',
                description: 'From zero to a working Kraft app. Gradle setup, entry point, first component.',
            },
            {
                href: '/ultra/kraft/examples',
                title: 'Live Examples',
                description: 'Hello World, Addons, and SemanticUI running in your browser.',
            },
        ],
    },
    {
        title: 'Core',
        items: [
            {
                href: '/ultra/kraft/components',
                title: 'Components',
                description: 'Class-based and functional components with props, state, and composition.',
            },
            {
                href: '/ultra/kraft/lifecycle-hooks',
                title: 'Lifecycle Hooks',
                description: 'onMount, onUpdate, onUnmount, onError (error boundaries), onResize, and window events.',
            },
            {
                href: '/ultra/kraft/state',
                title: 'State Management',
                description: 'Reactive state with value(), stream-backed state, and external stream subscriptions.',
            },
            {
                href: '/ultra/kraft/data-loading',
                title: 'Data Loading',
                description: 'Async data loading with loading, loaded, and error states. Reload and silent refresh.',
            },
            {
                href: '/ultra/kraft/dom-events',
                title: 'DOM Events',
                description: 'onClick, onInput, onKeyDown, and 50+ more — typed event handlers for every DOM event.',
            },
            {
                href: '/ultra/kraft/messaging',
                title: 'Messaging',
                description: 'Type-safe message passing between components, bubbling up the tree.',
            },
            {
                href: '/ultra/kraft/routing',
                title: 'Routing',
                description: 'Type-safe routes with parameters, middleware for auth guards, and nested layouts.',
            },
            {
                href: '/ultra/kraft/forms',
                title: 'Forms & Validation',
                description: 'Two-way binding, field validation, and the draft/commit pattern.',
            },
        ],
    },
    {
        title: 'UI',
        items: [
            {
                href: '/ultra/kraft/semantic-ui',
                title: 'SemanticUI DSL',
                description: 'A fluent Kotlin DSL for FomanticUI. Write ui.blue.button instead of CSS class strings.',
            },
            {
                href: '/ultra/kraft/overlays',
                title: 'Overlays',
                description: 'Modal dialogs, toast notifications, popup menus, and context menus.',
            },
            {
                href: '/ultra/kraft/drag-and-drop',
                title: 'Drag & Drop',
                description: 'Type-safe drag and drop with typed payloads and accept predicates.',
            },
        ],
    },
    {
        title: 'Ecosystem',
        items: [
            {
                href: '/ultra/kraft/utilities',
                title: 'Utilities',
                description: 'Responsive design, CSS-in-Kotlin, file handling, and responsive images.',
            },
            {
                href: '/ultra/kraft/testing',
                title: 'Testing',
                description: 'TestBed for rendering components, KQuery for DOM querying, event dispatch, and assertions.',
            },
            {
                href: '/ultra/kraft/addons',
                title: 'Addons',
                description: 'ChartJS, PDF viewer, syntax highlighting, signature pad, and 8 more JS libraries wrapped for Kotlin.',
            },
        ],
    },
];
---

<BaseLayout title="Kraft" description="Build single-page applications in pure Kotlin with Kraft">
    <HilbertBackground tint={categoryTints.kraft.light}/>
    <Nav/>

    <section class="pt-32 pb-12 px-4">
        <div class="mx-auto max-w-5xl">
            <div class="flex items-center justify-between mb-4">
                <h1 class="text-4xl font-extrabold text-white">Kraft</h1>
                <a href={githubSource.kraft} target="_blank" rel="noopener"
                   class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-brand-400 transition-colors">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
                    </svg>
                    View source
                </a>
            </div>
            <p class="text-xl text-gray-400 mb-2">
                Build single-page applications in pure Kotlin.
            </p>
            <p class="text-sm text-gray-500 mb-12">
                A component-based SPA framework using Preact under the hood.
                Type-safe HTML DSL, reactive state, routing, forms, and SemanticUI integration.
            </p>

            {sections.map(section => (
                    <div class="mb-10">
                        <h2 class="text-lg font-bold text-gray-500 uppercase tracking-wide mb-3">{section.title}</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            {section.items.map(item => (
                                    <a
                                            href={item.href}
                                            class="group block p-5 rounded-xl border border-brand-400/20 bg-[#161a2a]/65 hover:border-brand-400/50 hover:bg-[#161a2a]/75 hover:-translate-y-0.5 transition-all duration-300"
                                            style={`--glow: ${t.glow}; --glow-sm: ${t.glowSm};`}
                                            onmouseover="this.style.boxShadow='0 0 25px var(--glow), 0 0 8px var(--glow-sm)'"
                                            onmouseout="this.style.boxShadow='none'"
                                    >
                                        <h3 class="text-white font-bold mb-1">{item.title}</h3>
                                        <p class="text-sm text-gray-400">{item.description}</p>
                                    </a>
                            ))}
                        </div>
                    </div>
            ))}

            <div class="mb-10">
                <h2 class="text-lg font-bold text-gray-500 uppercase tracking-wide mb-3">Example Projects</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <a href="/ultra/kraft/examples"
                       class="group block p-5 rounded-xl border border-brand-400/20 bg-[#161a2a]/65 hover:border-brand-400/50 hover:bg-[#161a2a]/75 hover:-translate-y-0.5 transition-all duration-300"
                       style={`--glow: ${t.glow}; --glow-sm: ${t.glowSm};`}
                       onmouseover="this.style.boxShadow='0 0 25px var(--glow), 0 0 8px var(--glow-sm)'"
                       onmouseout="this.style.boxShadow='none'">
                        <h3 class="text-white font-bold mb-1">Live Examples</h3>
            <p class="text-sm text-gray-400">Hello World, Addons, and SemanticUI — running in your browser.</p>
                    </a>
                    <a href={kraftExamples.router} target="_blank" rel="noopener"
                       class="group block p-5 rounded-xl border border-brand-400/20 bg-[#161a2a]/65 hover:border-brand-400/50 hover:bg-[#161a2a]/75 hover:-translate-y-0.5 transition-all duration-300"
                       style={`--glow: ${t.glow}; --glow-sm: ${t.glowSm};`}
                       onmouseover="this.style.boxShadow='0 0 25px var(--glow), 0 0 8px var(--glow-sm)'"
                       onmouseout="this.style.boxShadow='none'">
                        <h3 class="text-white font-bold mb-1">Router Demo</h3>
                        <p class="text-sm text-gray-400">Multi-page app with parameterized routes and form handling with
                            Mutator.</p>
                    </a>
                    <a href={kraftExamples.remote} target="_blank" rel="noopener"
                       class="group block p-5 rounded-xl border border-brand-400/20 bg-[#161a2a]/65 hover:border-brand-400/50 hover:bg-[#161a2a]/75 hover:-translate-y-0.5 transition-all duration-300"
                       style={`--glow: ${t.glow}; --glow-sm: ${t.glowSm};`}
                       onmouseover="this.style.boxShadow='0 0 25px var(--glow), 0 0 8px var(--glow-sm)'"
                       onmouseout="this.style.boxShadow='none'">
                        <h3 class="text-white font-bold mb-1">Remote API</h3>
            <p class="text-sm text-gray-400">Consume REST APIs and display results with routing and SemanticUI.</p>
                    </a>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
