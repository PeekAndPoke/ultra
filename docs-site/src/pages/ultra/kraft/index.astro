<h2>Quick taste</h2>

<p>Here's a complete app with routing:</p>

<Code code={`fun main() {
    val app = kraftApp {
        semanticUI()
        routing {
            usePathStrategy()
            mount(Static("/")) { HomePage() }
            mount(Route1("/users/{id}")) { route ->
                UserPage(route["id"])
            }
        }
    }

    app.mount("#app", PreactVDomEngine()) {
        RouterComponent()
    }
}`} lang="kotlin" theme="vitesse-dark" />

