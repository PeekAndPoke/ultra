---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import HilbertBackground from '../components/HilbertBackground.astro';
import {githubSource, categoryTints, pathToCategory} from '../data/site';

interface Props {
  title: string;
  description?: string;
  sidebar: { href: string; label: string; section?: string }[];
    hilbert?: boolean; // show the lit Hilbert background (for landing pages)
}

const {title, description, sidebar, hilbert = false} = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';

// Derive GitHub source link from current path
const pathToSource: Record<string, string> = {
    '/ultra/kraft/': githubSource.kraft,
    '/ultra/mutator/': githubSource.mutator,
    '/ultra/kontainer/': githubSource.kontainer,
    '/ultra/slumber/': githubSource.slumber,
    '/ultra/streams/': githubSource.streams,
    '/ultra/datetime/': githubSource.datetime,
    '/ultra/cache/': githubSource.cache,
    '/ultra/karango/': githubSource.karango,
    '/ultra/funktor/': githubSource.funktor,
    '/ultra/monko/': githubSource.monko,
};
const githubUrl = Object.entries(pathToSource).find(([prefix]) => currentPath.startsWith(prefix))?.[1];

// Resolve category tint from centralized constants
const categoryKey = Object.entries(pathToCategory).find(([prefix]) => currentPath.startsWith(prefix))?.[1];
const colors = categoryKey ? categoryTints[categoryKey] : undefined;
const lightTint = colors?.light;
const bodyBg = colors?.bg ?? '#0e0d0b';
const borderTint = colors?.border ?? 'rgba(255,255,255,0.1)';

// Group sidebar items by section
const sections = sidebar.reduce((acc, item) => {
  const section = item.section || '';
  if (!acc[section]) acc[section] = [];
  acc[section].push(item);
  return acc;
}, {} as Record<string, typeof sidebar>);
---

<BaseLayout title={title} description={description}>
    {hilbert && lightTint &&
            <HilbertBackground tint={lightTint}/>}
  <Nav />
    <div class="pt-16 flex" style={`background-color: ${bodyBg};`}>
    <!-- Sidebar -->
        <aside class="fixed top-16 left-0 bottom-0 w-64 overflow-y-auto p-4 hidden lg:block"
               style={`border-right: 1px solid ${borderTint}; background-color: ${hilbert ? 'transparent' : bodyBg};`}>
      <nav class="space-y-6">
        {Object.entries(sections).map(([section, items]) => (
          <div>
            {section && (
              <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2 px-3">
                {section}
              </h3>
            )}
            <ul class="space-y-0.5">
              {items.map(item => (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      'block px-3 py-1.5 rounded-md text-sm transition-colors',
                      currentPath === (item.href.replace(/\/+$/, '') || '/')
                        ? 'text-brand-400 bg-brand-400/10 font-medium'
                        : 'text-gray-400 hover:text-white hover:bg-white/5',
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
          {githubUrl && (
                  <div class="mt-6 px-3">
                      <a href={githubUrl} target="_blank" rel="noopener"
                         class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-brand-400 transition-colors">
                          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16">
                              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
                          </svg>
                          View source
                      </a>
                  </div>
          )}
      </nav>
    </aside>

    <!-- Main content -->
        <main class="flex-1 lg:ml-64 min-h-screen" style={hilbert ? '' : `background-color: ${bodyBg};`}>
      <article class="mx-auto max-w-4xl px-6 py-12 prose prose-invert prose-headings:text-white prose-a:text-brand-400 prose-code:text-brand-300 prose-strong:text-white max-w-none">
        <slot />
      </article>
    </main>
  </div>
</BaseLayout>
