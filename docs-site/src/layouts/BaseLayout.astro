---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Open source Kotlin libraries for building modern applications' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
      <link rel="llms" href="/llms.txt"/>
    <title>{title} | peekandpoke.io</title>

      <!-- GoatCounter analytics (cookie-free, GDPR compliant) -->
      <script data-goatcounter="https://peekandpoke.goatcounter.com/count"
              async src="//gc.zgo.at/count.js"></script>
  </head>
  <body class="bg-surface-900 text-gray-200 font-sans antialiased">
    <slot />
    <footer class="py-8 px-6 border-t border-white/5">
        <div class="max-w-4xl mx-auto text-center text-sm text-gray-600">
            <p>
                &copy; {new Date().getFullYear()} Karsten J. Gerber
                <span class="mx-2 text-white/10">|</span>
                <a href="/legal" class="text-gray-600 hover:text-brand-400 transition-colors">Legal / Impressum</a>
            </p>
        </div>
    </footer>
  </body>
</html>
